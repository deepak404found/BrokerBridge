# BrokerBridge — sample env placeholders only.
# Copy to .env and replace with your Local Lab values. Never commit .env.
#
# Docker Compose reads .env for:
#   - ${POSTGRES_*} substitution on the postgres service
#   - env_file on api/worker
# For compose Local Lab, use service hostnames (postgres/redis/redpanda).
# For host-side tooling against published ports, use localhost instead
#   (e.g. REDPANDA_BROKERS=localhost:19092 — see docker-compose advertise-kafka-addr).
APP_ENV=lab
APP_NAME=BrokerBridge API
LOG_LEVEL=INFO
DOCS_ENABLED=true
ADMIN_UI_ENABLED=true

POSTGRES_USER=USER
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DB=DB_NAME
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@postgres:5432/DB_NAME
REDIS_URL=redis://redis:6379/0

# Event bus bootstrap (optional; overridden by active provider_configs kind=event)
# Local Compose cold-start: redpanda_local + PLAINTEXT (no user/pass).
# Day-2 cloud swap: Admin Runtime Config validate → activate (preferred), not .env alone.
EVENT_PROVIDER=redpanda_local
REDPANDA_BROKERS=redpanda:9092
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SSL=false
KAFKA_TOPIC_PREFIX=brokerbridge.events
KAFKA_CONSUMER_GROUP=brokerbridge-lab
#
# Cloud-shaped example (leave commented in Local Lab .env; fill in Admin or Render dashboard):
# EVENT_PROVIDER=redpanda_cloud
# KAFKA_BOOTSTRAP_SERVERS=YOUR_CLUSTER.cloud.redpanda.com:9092
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=SCRAM-SHA-256
# KAFKA_USERNAME=YOUR_USER
# KAFKA_PASSWORD=YOUR_PASSWORD
# KAFKA_SSL=true

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
SECRETS_FERNET_KEY=generate-a-fernet-key
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme

# Infrastructure bootstrap (FR-21 cold start). Active provider_configs kind=infrastructure wins.
# Types: mock | vultr. Prefer Admin Runtime Config for Vultr api_key (no .env edit / no restart).
INFRA_PROVIDER=mock
# When INFRA_PROVIDER=mock (or active type=mock):
#   database = Render/CI/demo — Postgres-simulated instances/IPs; no Docker Engine required
#   docker   = Local Lab realism — Docker Engine containers as instances
# Cold-start default is database. Compose Local Lab mounts /var/run/docker.sock so you can
# Admin-activate mock_backend=docker without a separate override. Restart does NOT reset
# a previously activated docker backend in Postgres — switch back via Admin if needed.
MOCK_INFRA_BACKEND=database
# Optional legacy Vultr fallback only (ignored when DB provider_configs active for infrastructure):
# VULTR_API_KEY=
# VULTR_DEFAULT_REGION=ewr
#
# Local Lab Docker Engine (mounted by default in docker-compose.yml):
# DOCKER_HOST=unix:///var/run/docker.sock
# SECURITY: Socket mount lets api/worker control the host Docker daemon — trusted machines only.
# Force docker backend at cold start (optional):
#   docker compose -f docker-compose.yml -f docker-compose.docker-infra.yml up --build
# If docker is active in DB but the socket is missing, API falls back to database and Admin
# shows a degradation banner (no opaque 500s).
BROKER_PROVIDER=mock
LOCK_PROVIDER=redis
SESSION_PROVIDER=redis
RATE_LIMIT_PROVIDER=redis
MAX_INFLIGHT_ORDERS=100
IP_REUSE_COOLDOWN_HOURS=24
