# BrokerBridge — sample env placeholders only.
# Copy to .env and replace with your Local Lab values. Never commit .env.
#
# Docker Compose reads .env for:
#   - ${POSTGRES_*} substitution on the postgres service
#   - env_file on api/worker
# For compose Local Lab, use service hostnames (postgres/redis/redpanda).
# For host-side tooling against published ports, use localhost instead.
APP_ENV=lab
APP_NAME=BrokerBridge API
LOG_LEVEL=INFO
DOCS_ENABLED=true
ADMIN_UI_ENABLED=true

POSTGRES_USER=USER
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DB=DB_NAME
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@postgres:5432/DB_NAME
REDIS_URL=redis://redis:6379/0
REDPANDA_BROKERS=redpanda:9092

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
SECRETS_FERNET_KEY=generate-a-fernet-key
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme

INFRA_PROVIDER=mock
BROKER_PROVIDER=mock
LOCK_PROVIDER=redis
SESSION_PROVIDER=redis
RATE_LIMIT_PROVIDER=redis
MAX_INFLIGHT_ORDERS=100
IP_REUSE_COOLDOWN_HOURS=24
