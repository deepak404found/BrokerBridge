# BrokerBridge Local Lab — copy to .env and adjust as needed
APP_ENV=dev
APP_NAME=BrokerBridge API
LOG_LEVEL=INFO
DOCS_ENABLED=true
ADMIN_UI_ENABLED=true
DATABASE_URL=postgresql+asyncpg://brokerbridge:brokerbridge@localhost:5432/brokerbridge
REDIS_URL=redis://localhost:6379/0
REDPANDA_BROKERS=localhost:19092
